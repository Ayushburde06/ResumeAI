# ⚠️  ROTATE ALL KEYS BELOW — previous values were exposed. Get new ones from each provider.
#     This file is git-ignored. Never commit real credentials.

# ── App Security ─────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING

# ── CORS (comma-separated origins allowed to call the API) ───────────────────
# Dev:  http://localhost:5173
# Prod: https://your-frontend.vercel.app,https://your-custom-domain.com
ALLOWED_ORIGINS=http://localhost:5173

# ── Model Configuration ──────────────────────────────────────────────────────
DEFAULT_MODEL_ID=glm

# ── Qwen ─────────────────────────────────────────────────────────────────────
QWEN_API_KEY=YOUR_QWEN_API_KEY_HERE
QWEN_ENDPOINT=https://bedrock-mantle.us-east-1.api.aws/v1
QWEN_MODEL=qwen.qwen3-235b-a22b-2507

# ── GLM-5 ────────────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=YOUR_GLM_API_KEY_HERE
AZURE_OPENAI_ENDPOINT=https://bedrock-mantle.us-east-1.api.aws/v1
AZURE_OPENAI_DEPLOYMENT=zai.glm-5
AZURE_OPENAI_API_VERSION=2024-05-01-preview

# ── GLM-4.7 Flash ─────────────────────────────────────────────────────────────
GLM_FLASH_API_KEY=YOUR_GLM_FLASH_API_KEY_HERE
GLM_FLASH_ENDPOINT=https://bedrock-mantle.us-east-1.api.aws/v1
GLM_FLASH_MODEL=zai.glm-4.7-flash

# ── Database (optional, defaults to SQLite for local dev) ────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/resumeai
